# ---------------------------------------------------------------------------
# Next.js / Vercel environment — copy to `.env.local` and fill in real values.
# `.env.local` is git-ignored by the framework default. NEVER commit real keys.
#
# The Streamlit app reads the older `.env` file at the repo root — that stays
# untouched. These are the Next.js-only vars for the Vercel rebuild.
# ---------------------------------------------------------------------------

# Supabase project URL + service_role key (server-only, bypasses RLS).
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SECRET=<service_role-key>

# GitHub workflow dispatch — kicks off engine/runner.py in GitHub Actions.
GITHUB_REPO_OWNER=<owner>
GITHUB_REPO_NAME=<repo>
GITHUB_DISPATCH_TOKEN=ghp_xxx

# Optional — override the workflow file or branch if you've renamed either.
# GITHUB_WORKFLOW=indexing-monitor.yml
# GITHUB_REF=main
