{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/sweep-stale-runs",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scheduled-run",
      "schedule": "0 */6 * * *"
    }
  ]
}
