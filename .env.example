# ---------------------------------------------------------------------------
# indexing-monitor configuration
#
# Copy this file to `.env` and fill in the real values.
# Never commit `.env` — it's already in .gitignore.
# ---------------------------------------------------------------------------

# The public sitemap URL. Supports sitemap index files and .xml.gz files.
SITEMAP_URL=https://example.com/sitemap.xml

# Your Google Search Console property in its canonical form.
#   URL-prefix property:  https://example.com/
#   Domain property:      sc-domain:example.com
# The URL Inspection API needs this — it's the verified property, not the page URL.
GSC_SITE_URL=https://example.com/

# Service account credentials. Two formats are supported:
#   1. A filesystem path to the JSON file:   /absolute/path/to/service-account.json
#   2. The raw JSON itself as a single string starting with `{`
# The code auto-detects which one you gave it. For GitHub Actions, paste the
# raw JSON directly as a repo secret (option 2).
GOOGLE_CREDENTIALS=/absolute/path/to/service-account.json

# ---------------------------------------------------------------------------
# Optional safety limits — defaults are already sensible.
# ---------------------------------------------------------------------------

# Stop submitting URLs to the Indexing API after this many per run.
# Google's default daily Indexing API quota is 200 requests/project — leave
# headroom so you don't hit the wall mid-run.
MAX_SUBMISSIONS_PER_RUN=180

# If a URL keeps coming back "not indexed" after this many submissions,
# give up and flag it in the `notes` column. Prevents infinite retry loops.
MAX_SUBMIT_ATTEMPTS_PER_URL=5

# ---------------------------------------------------------------------------
# Discord notifications (optional)
#
# When a run finishes (success or failure), the engine posts a single embed
# to this webhook with the per-run stats: total tracked, indexed, not
# indexed, submitted to the Indexing API, duration, and a link back to the
# client page on the dashboard. Leave blank to disable.
#
# Create one in Discord: Server Settings → Integrations → Webhooks → New
# Webhook → Copy URL. Add the same value as a repo secret named
# DISCORD_WEBHOOK_URL so GitHub Actions can use it too. Also add it as a
# Vercel env var (production) — the daily-report cron uses it.
# ---------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=

# Optional — failures route here instead. Falls back to the main webhook
# when unset. Useful if you want to keep "all good" runs in #ops and
# "something broke" alerts in a dedicated #alerts channel.
DISCORD_ERROR_WEBHOOK_URL=
